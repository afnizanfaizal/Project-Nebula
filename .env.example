# ── Firebase Client SDK (public — safe to expose in your repository) ─────────
PUBLIC_FIREBASE_API_KEY=
PUBLIC_FIREBASE_AUTH_DOMAIN=
PUBLIC_FIREBASE_PROJECT_ID=
PUBLIC_FIREBASE_STORAGE_BUCKET=
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
PUBLIC_FIREBASE_APP_ID=

# ── Firebase Admin SDK (server-side only — NEVER expose publicly) ─────────────
# These are required for the admin panel, session auth, and Firestore access.
# Obtain them from your Firebase project → Project Settings → Service accounts.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Paste the private key exactly as-is from the JSON, including -----BEGIN ... -----
FIREBASE_PRIVATE_KEY=

# ── Migration script only ─────────────────────────────────────────────────────
# Path to a downloaded service account JSON file — used by scripts/migrate.js only.
# Never commit this file; it is already in .gitignore.
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

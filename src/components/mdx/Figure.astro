---
// src/components/mdx/Figure.astro
// Used in blog posts as: <Figure src="/uploads/xxx.jpg" align="left" caption="..." />
// Registered globally via components prop in blog/[slug].astro — no import needed in MDX.
interface Props {
  src: string;
  alt?: string;
  align?: 'left' | 'right' | 'center' | 'none';
  caption?: string;
}
const { src, alt = '', align = 'none', caption } = Astro.props;
---

<figure class:list={['blog-figure', `figure-${align}`]}>
  <img src={src} alt={alt} loading="lazy" />
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .blog-figure {
    margin: 0;
  }

  /* Float left — text wraps to the right */
  .figure-left {
    float: left;
    max-width: 45%;
    margin: 0.25rem 1.75rem 1rem 0;
  }

  /* Float right — text wraps to the left */
  .figure-right {
    float: right;
    max-width: 45%;
    margin: 0.25rem 0 1rem 1.75rem;
  }

  /* Centred block — no text wrap */
  .figure-center {
    display: block;
    margin: 1.5rem auto;
    text-align: center;
    max-width: 100%;
  }

  /* Full-width block — no text wrap */
  .figure-none {
    display: block;
    margin: 1.5rem 0;
    max-width: 100%;
  }

  .blog-figure img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 0.375rem;
  }

  figcaption {
    margin-top: 0.5rem;
    font-size: 0.8125rem;
    color: #6b7280;
    text-align: center;
    font-style: italic;
  }

  /* Clear floats after article sections */
  .blog-figure + * {
    /* downstream layout handles clearfix */
  }
</style>

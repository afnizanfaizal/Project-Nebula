---
export const prerender = false;
import { listPosts } from '../../lib/firebase-admin.js';
import Layout from '../../layouts/Layout.astro';

// Fetch all posts, filter to only those marked as projects & not drafts
const allProjects = (await listPosts())
  .filter((p) => !p.draft && p.isProject)
  .sort((a, b) => new Date(b.pubDate).valueOf() - new Date(a.pubDate).valueOf());

const POSTS_PER_PAGE = 6;
const initialProjects = allProjects.slice(0, POSTS_PER_PAGE);
const hasMorePages = allProjects.length > POSTS_PER_PAGE;
---
<Layout title="Projects — Dr. Afnizanfaizal" description="Research and engineering projects.">
  <div class="relative min-h-dvh bg-[#050508]">
    <!-- Ambient glow orbs -->
    <div aria-hidden="true" class="pointer-events-none absolute -top-40 -left-48 h-[600px] w-[600px] rounded-full bg-indigo-700/20 blur-[130px]"></div>
    <div aria-hidden="true" class="pointer-events-none absolute top-1/2 -right-60 h-[500px] w-[500px] rounded-full bg-purple-700/[0.12] blur-[110px]"></div>
    <div aria-hidden="true" class="pointer-events-none absolute bottom-0 left-1/3 h-[400px] w-[400px] rounded-full bg-blue-600/[0.08] blur-[100px]"></div>

    <div class="relative mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
      <div class="sm:pl-[34px]">
        <header class="mb-12">
          <h1 class="text-4xl font-bold tracking-tight text-white mb-4">Projects</h1>
          <p class="text-lg text-white/40 max-w-2xl">Selected research and engineering work.</p>
        </header>

        <section id="projects-section">
          <!-- Header + Search -->
          <div class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
            <div>
              <h2 class="text-xl font-semibold text-white">All Projects</h2>
              <p class="mt-0.5 text-sm text-white/35" id="posts-count">
                {allProjects.length} {allProjects.length === 1 ? 'project' : 'projects'}
              </p>
            </div>

            <!-- Search input -->
            <div class="relative">
              <svg
                class="pointer-events-none absolute left-3.5 top-1/2 h-4 w-4 -translate-y-1/2 text-white/30"
                viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"
              >
                <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
              </svg>
              <input
                id="search-input"
                type="text"
                placeholder="Search projects…"
                class="w-full rounded-xl border border-white/10 bg-white/[0.06] py-2.5 pl-10 pr-4 text-sm text-white placeholder-white/30 backdrop-blur-sm transition-all focus:border-indigo-500/50 focus:bg-white/10 focus:outline-none focus:ring-1 focus:ring-indigo-500/30 sm:w-64"
              />
            </div>
          </div>

          <!-- Projects grid -->
          <div id="posts-grid" class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {initialProjects.map(project => (
              <a
                href={`/blog/${project.slug}`}
                class="group flex cursor-pointer flex-col overflow-hidden rounded-2xl border border-white/10 bg-white/[0.05] backdrop-blur-sm transition-all duration-300 hover:border-white/20 hover:bg-white/[0.09] hover:shadow-xl hover:shadow-indigo-500/[0.08]"
              >
                <div class="relative aspect-video overflow-hidden">
                  {project.featuredImage ? (
                    <img
                      src={project.featuredImage}
                      alt={project.title}
                      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                      loading="lazy"
                    />
                  ) : (
                    <div class="flex h-full w-full items-center justify-center bg-gradient-to-br from-indigo-900/60 via-purple-900/50 to-slate-900/60">
                      <svg class="h-10 w-10 text-white/10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M4 4h16v16H4z"/><path d="M4 9h16M9 4v16"/>
                      </svg>
                    </div>
                  )}
                  <div class="absolute inset-x-0 bottom-0 h-12 bg-gradient-to-t from-[#050508]/80 to-transparent"></div>
                </div>

                <div class="flex flex-1 flex-col p-5">
                  <div class="mb-3 flex flex-wrap gap-1.5">
                    {project.tags.filter(t => t.toUpperCase() !== 'PROJECT').slice(0, 2).map(tag => (
                      <span class="rounded-md border border-indigo-500/20 bg-indigo-500/10 px-2 py-0.5 text-[10px] lowercase text-indigo-300">
                        #{tag}
                      </span>
                    ))}
                  </div>

                  <h3 class="mb-2 line-clamp-2 text-base font-semibold leading-snug text-white transition-colors group-hover:text-indigo-200">
                    {project.title}
                  </h3>

                  <p class="mb-4 line-clamp-2 flex-1 text-sm leading-relaxed text-white/45">
                    {project.description}
                  </p>

                  <div class="mt-auto flex items-center justify-between border-t border-white/[0.07] pt-3">
                    <span class="text-[10px] text-white/30 uppercase tracking-widest font-medium">Project</span>
                    <svg class="h-4 w-4 text-white/25 transition-all group-hover:translate-x-0.5 group-hover:text-indigo-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M5 12h14M12 5l7 7-7 7"/>
                    </svg>
                  </div>
                </div>
              </a>
            ))}
          </div>

          <!-- Empty search state -->
          <div id="empty-state" class="hidden py-20 text-center">
            <svg class="mx-auto mb-4 h-12 w-12 text-white/10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
            </svg>
            <p class="text-base text-white/30">No projects match your search</p>
          </div>

          <!-- Pagination -->
          <div
            id="pagination"
            class={`mt-10 flex items-center justify-center gap-2 ${hasMorePages ? '' : 'hidden'}`}
            aria-label="Project pagination"
          >
            <button
              id="prev-btn"
              disabled
              aria-label="Previous page"
              class="rounded-xl border border-white/10 bg-white/[0.05] px-4 py-2 text-sm text-white/50 backdrop-blur-sm transition-all hover:bg-white/10 hover:text-white disabled:cursor-not-allowed disabled:opacity-30"
            >
              ← Prev
            </button>
            <div id="page-numbers" class="flex gap-1.5" role="list"></div>
            <button
              id="next-btn"
              aria-label="Next page"
              class="rounded-xl border border-white/10 bg-white/[0.05] px-4 py-2 text-sm text-white/50 backdrop-blur-sm transition-all hover:bg-white/10 hover:text-white disabled:cursor-not-allowed disabled:opacity-30"
            >
              Next →
            </button>
          </div>
        </section>
      </div>
    </div>
  </div>

  <script is:inline type="application/json" id="all-projects-data" set:html={JSON.stringify(allProjects)}></script>

  <script>
    // ── Constants ────────────────────────────────────────────────────────
    const POSTS_PER_PAGE = 6;

    // ── Data ────────────────────────────────────────────────────────────
    const dataEl = document.getElementById('all-projects-data');
    const allProjects = JSON.parse(dataEl?.textContent ?? '[]');
    let filtered = [...allProjects];
    let currentPage = 1;

    const grid = document.getElementById('posts-grid')!;
    const emptyState = document.getElementById('empty-state')!;
    const countEl = document.getElementById('posts-count')!;
    const searchInput = document.getElementById('search-input') as HTMLInputElement;
    const pagination = document.getElementById('pagination')!;
    const prevBtn = document.getElementById('prev-btn') as HTMLButtonElement;
    const nextBtn = document.getElementById('next-btn') as HTMLButtonElement;
    const pageNumbers = document.getElementById('page-numbers')!;

    function escapeHtml(str: string) {
      return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    function render() {
      countEl.textContent = `${filtered.length} ${filtered.length === 1 ? 'project' : 'projects'}`;
      
      if (filtered.length === 0) {
        grid.classList.add('hidden');
        emptyState.classList.remove('hidden');
        pagination.classList.add('hidden');
        return;
      }

      grid.classList.remove('hidden');
      emptyState.classList.add('hidden');

      const start = (currentPage - 1) * POSTS_PER_PAGE;
      const pagePosts = filtered.slice(start, start + POSTS_PER_PAGE);

      grid.innerHTML = pagePosts.map(project => {
        const tags = project.tags
          .filter((t: string) => t.toUpperCase() !== 'PROJECT')
          .slice(0, 2)
          .map((t: string) => `<span class="rounded-md border border-indigo-500/20 bg-indigo-500/10 px-2 py-0.5 text-[10px] lowercase text-indigo-300">#${escapeHtml(t)}</span>`)
          .join('');

        const thumbnail = project.featuredImage
          ? `<img src="${escapeHtml(project.featuredImage)}" alt="" class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />`
          : `<div class="flex h-full w-full items-center justify-center bg-gradient-to-br from-indigo-900/60 via-purple-900/50 to-slate-900/60"><svg class="h-10 w-10 text-white/10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16v16H4z"/><path d="M4 9h16M9 4v16"/></svg></div>`;

        return `
          <a href="/blog/${escapeHtml(project.slug)}" class="group flex cursor-pointer flex-col overflow-hidden rounded-2xl border border-white/10 bg-white/[0.05] backdrop-blur-sm transition-all duration-300 hover:border-white/20 hover:bg-white/[0.09] hover:shadow-xl hover:shadow-indigo-500/[0.08]">
            <div class="relative aspect-video overflow-hidden">
              ${thumbnail}
              <div class="absolute inset-x-0 bottom-0 h-12 bg-gradient-to-t from-[#050508]/80 to-transparent"></div>
            </div>
            <div class="flex flex-1 flex-col p-5">
              <div class="mb-3 flex flex-wrap gap-1.5">${tags}</div>
              <h3 class="mb-2 line-clamp-2 text-base font-semibold leading-snug text-white transition-colors group-hover:text-indigo-200">
                ${escapeHtml(project.title)}
              </h3>
              <p class="mb-4 line-clamp-2 flex-1 text-sm leading-relaxed text-white/45">${escapeHtml(project.description)}</p>
              <div class="mt-auto flex items-center justify-between border-t border-white/[0.07] pt-3">
                <span class="text-[10px] text-white/30 uppercase tracking-widest font-medium">Project</span>
                <svg class="h-4 w-4 text-white/25 transition-all group-hover:translate-x-0.5 group-hover:text-indigo-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </div>
            </div>
          </a>`;
      }).join('');

      renderPagination();
    }

    function renderPagination() {
      const totalPages = Math.ceil(filtered.length / POSTS_PER_PAGE);

      if (totalPages <= 1) {
        pagination.classList.add('hidden');
        return;
      }

      pagination.classList.remove('hidden');
      prevBtn.disabled = currentPage === 1;
      nextBtn.disabled = currentPage === totalPages;

      // Build page number buttons (show max 5 page pills)
      const maxPills = 5;
      let pages: (number | '…')[] = [];
      if (totalPages <= maxPills) {
        pages = Array.from({ length: totalPages }, (_, i) => i + 1);
      } else {
        pages = [1];
        const left = Math.max(2, currentPage - 1);
        const right = Math.min(totalPages - 1, currentPage + 1);
        if (left > 2) pages.push('…');
        for (let i = left; i <= right; i++) pages.push(i);
        if (right < totalPages - 1) pages.push('…');
        pages.push(totalPages);
      }

      pageNumbers.innerHTML = pages.map(p =>
        p === '…'
          ? `<span class="flex h-9 w-9 items-center justify-center text-sm text-white/25">…</span>`
          : `<button
               role="listitem"
               data-page="${p}"
               aria-label="Page ${p}"
               aria-current="${p === currentPage ? 'page' : 'false'}"
               class="h-9 w-9 rounded-lg text-sm transition-all cursor-pointer ${p === currentPage
                 ? 'bg-indigo-600 font-semibold text-white shadow-lg shadow-indigo-600/30'
                 : 'border border-white/10 bg-white/[0.05] text-white/50 hover:bg-white/10 hover:text-white'
               }"
             >${p}</button>`
      ).join('');

      pageNumbers.querySelectorAll<HTMLButtonElement>('[data-page]').forEach(btn => {
        btn.addEventListener('click', () => {
          currentPage = parseInt(btn.dataset.page!);
          render();
          document.getElementById('projects-section')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
      });
    }

    searchInput?.addEventListener('input', e => {
      const q = (e.target as HTMLInputElement).value.toLowerCase().trim();
      filtered = q
        ? allProjects.filter((p: any) => 
            p.title.toLowerCase().includes(q) || 
            (p.description || '').toLowerCase().includes(q) ||
            p.tags.some((t: string) => t.toLowerCase().includes(q))
          )
        : [...allProjects];
      currentPage = 1;
      render();
    });

    prevBtn?.addEventListener('click', () => {
      if (currentPage > 1) {
        currentPage--;
        render();
        document.getElementById('projects-section')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });

    nextBtn?.addEventListener('click', () => {
      const total = Math.ceil(filtered.length / POSTS_PER_PAGE);
      if (currentPage < total) {
        currentPage++;
        render();
        document.getElementById('projects-section')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });

    // Initial pagination render
    renderPagination();
  </script>
</Layout>
